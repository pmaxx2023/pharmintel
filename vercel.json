{
  "functions": {
    "api/chat.js": { "maxDuration": 60 },
    "api/news.js": { "maxDuration": 15 },
    "api/voices.js": { "maxDuration": 15 },
    "api/extract.js": { "maxDuration": 10 }
  },
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
